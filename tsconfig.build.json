{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/**/*.demo.tsx",
    "src/**/*.stories.tsx",
    "src/examples/**/*",
    "tests/**/*",
    "dist/**/*"
  ]
}
